<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <PropertyGroup>
    <GameDataPath Condition="'$(GameDataPath)' == '' and Exists('$(MSBuildProjectDirectory)\\..\\..\\game_libs\\sts2.dll')">$(MSBuildProjectDirectory)\..\..\game_libs</GameDataPath>
    <GameDataPath Condition="'$(GameDataPath)' == '' and '$(STS2_DATA_PATH)' != ''">$(STS2_DATA_PATH)</GameDataPath>
    <GameDataPath Condition="'$(GameDataPath)' == ''">I:\SteamLibrary\steamapps\common\Slay the Spire 2\data_sts2_windows_x86_64</GameDataPath>
  </PropertyGroup>

  <ItemGroup>
    <Reference Include="sts2">
      <HintPath>$(GameDataPath)\sts2.dll</HintPath>
      <Private>true</Private>
    </Reference>
    <Reference Include="0Harmony">
      <HintPath>$(GameDataPath)\0Harmony.dll</HintPath>
      <Private>false</Private>
    </Reference>
  </ItemGroup>

</Project>
